# Clean Blue — Apache config (για τον σημερινό πάροχο / cPanel hosting)
# Αν ανεβάσεις σε Cloudflare Pages/Netlify, αγνόησέ το — εκεί δουλεύει το αρχείο _redirects.

RewriteEngine On

# --- Force HTTPS + non-www (canonical: https://cleanblue.gr) ---
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://cleanblue.gr%{REQUEST_URI} [L,R=301]

# --- 301 redirects από παλιά / διπλά URLs ---
Redirect 301 /archiki/ /
Redirect 301 /feed/ /
Redirect 301 /comments/feed/ /
# Ελληνικό διπλό URL (γενικοί -> genikoi)
RedirectMatch 301 ^/%CE%B3%CE%B5%CE%BD%CE%B9%CE%BA%CE%BF%CE%AF/?$ /genikoi/

# --- Καθαρά URLs: σερβίρισμα index.html για φακέλους (συνήθως ήδη ενεργό) ---
DirectoryIndex index.html

# --- Cache: μεγάλη διάρκεια για assets, καθόλου για HTML ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# --- HTML: πάντα φρέσκο (αποφυγή stale μετά από αλλαγές) ---
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js|woff2?|ttf|eot|jpg|jpeg|png|webp|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>
</IfModule>

# --- Συμπίεση (gzip) ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml font/woff2 font/ttf
</IfModule>

# --- Custom 404 (προαιρετικό) ---
# ErrorDocument 404 /404.html
